# Tracking Management System — Environment Variables Reference
# Copy this to apps/web/.env.local and fill in values

# Supabase (https://supabase.com/dashboard → project → settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # keep secret, server-only

# MSG91 (https://msg91.com → API → authkey)
MSG91_AUTH_KEY=your-msg91-authkey
MSG91_SENDER_ID=EPRVHN

# Razorpay (https://dashboard.razorpay.com → settings → API keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# MapmyIndia / Mappls (https://apis.mappls.com → console)
NEXT_PUBLIC_MAPPLS_API_KEY=your-mappls-api-key
NEXT_PUBLIC_MAPPLS_MAP_SDK_KEY=your-mappls-map-sdk-key

# Google Maps (Places Autocomplete + Map display)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
